# AI Radar — Environment Variables
# Copy this file to .env and fill in your API keys.

# At least one AI provider is needed for summarization.
# If both are set, Gemini is tried first with Claude as fallback.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Email digest via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_RECIPIENTS=you@example.com,team@example.com

# Optional: Dashboard URL for email links
DASHBOARD_URL=https://c0de-mule.github.io/ai-radar/
